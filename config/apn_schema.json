{
  "type": "object",
  "required": ["name", "apn", "mcc", "mnc", "type"],
  "properties": {
    "name": { "type": "string" },
    "apn": { "type": "string" },
    "mcc": { "type": "string", "pattern": "^[0-9]{3}$" },
    "mnc": { "type": "string", "pattern": "^[0-9]{2,3}$" },
    "type": { "type": "string" },
    "proxy": { "type": ["string", "null"] },
    "port": { "type": ["string", "null"] },
    "user": { "type": ["string", "null"] },
    "password": { "type": ["string", "null"] },
    "server": { "type": ["string", "null"] },
    "mmsc": { "type": ["string", "null"] },
    "mmsproxy": { "type": ["string", "null"] },
    "mmsport": { "type": ["string", "null"] },
    "auth_type": { "type": ["string", "null"] },
    "protocol": { "type": ["string", "null"] },
    "roaming_protocol": { "type": ["string", "null"] },
    "carrier_enabled": { "type": ["boolean", "null"] }
  }
}
